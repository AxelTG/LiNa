# vim: ft=plumed
#RESTART
UNITS LENGTH=A TIME=0.001  #Amstroeng, kJ/mol, fs

Na: GROUP ATOMS=1-1000:1
N: GROUP ATOMS=1001
H: GROUP ATOMS=1002

c: COORDINATIONNUMBER SPECIESA=N SPECIESB=H R_0=2.0 NN=6 MM=12 MAX={BETA=0.05} MIN={BETA=20.0} MEAN
#uwall: UPPER_WALLS ARG=dn AT=10.0 KAPPA=1000.0 EXP=2.0

PRINT ARG=* STRIDE=2000 FILE=COLVAR
FLUSH STRIDE=1
